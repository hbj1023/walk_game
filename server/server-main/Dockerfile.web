FROM ghcr.io/cirruslabs/flutter:stable AS build

WORKDIR /app
RUN flutter --version
COPY client/client-main/pubspec.yaml client/client-main/pubspec.lock ./
RUN flutter pub get

COPY client/client-main/ ./
RUN flutter build web --release --dart-define=API_BASE_URL=

FROM nginx:1.27-alpine
COPY server/server-main/nginx/game.conf /etc/nginx/conf.d/default.conf
COPY server/server-main/nginx/proxy-common.inc /etc/nginx/proxy-common.inc
COPY --from=build /app/build/web /usr/share/nginx/html
